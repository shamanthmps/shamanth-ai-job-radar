# Streamlit Cloud secrets template
# Copy this file to .streamlit/secrets.toml and fill in your values.
# This file is gitignored — never commit your actual secrets.toml.
#
# On Streamlit Community Cloud (free tier), add these via:
#   Dashboard → Your app → Settings → Secrets

DATABASE_URL = "postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres"

GROQ_API_KEY = "gsk_..."
GEMINI_API_KEY = "AIza..."
LLM_MODEL = "groq/llama-3.3-70b-versatile"
LLM_CALL_DELAY = "2.5"

TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""

GMAIL_ADDRESS = "your.personal@gmail.com"
GMAIL_APP_PASSWORD = "xxxx-xxxx-xxxx-xxxx"
ALERT_EMAIL_TO = "your.personal@gmail.com"
