# JobRadar — Environment Configuration
# ============================================================
# PERSONAL PROJECT — ALL credentials must be PERSONAL accounts.
# NEVER use GEHC credentials, corporate SSO, or work email here.
# See docs/COMPLIANCE.md for the full policy.
# ============================================================

# ----------------------------------------------------------
# AI / LLM — FREE TIER ONLY (no paid subscriptions)
# ----------------------------------------------------------

# OPTION 1 — Groq (RECOMMENDED): 14,400 req/day free, no credit card required
# Sign up at https://console.groq.com using your personal Google account
GROQ_API_KEY=gsk_...

# OPTION 2 — Google Gemini Flash: 15 RPM, 1M tokens/day free
# Get key at https://aistudio.google.com/app/apikey (personal Google account)
GEMINI_API_KEY=AIza...

# OPTION 3 — Ollama (fully local, zero cost, no API key needed)
# Install: https://ollama.ai  then run: ollama pull llama3.2
# Uncomment the line below and set LLM_MODEL=ollama/llama3.2
# OLLAMA_API_BASE=http://localhost:11434

# Which model to use — choose one that matches your API key above:
#   groq/llama-3.3-70b-versatile   ← Best quality, Groq free tier
#   groq/llama-3.1-8b-instant      ← Fastest, Groq free tier
#   gemini/gemini-1.5-flash        ← Google free tier
#   gemini/gemini-2.0-flash-exp    ← Newer Google model, free tier
#   ollama/llama3.2                ← Fully local, no internet needed
LLM_MODEL=groq/llama-3.3-70b-versatile

# Seconds to wait between AI calls (respect free tier rate limits):
#   Groq free:   2.5s (30 req/min limit)
#   Gemini free: 4.5s (15 req/min limit)
#   Ollama:      0.5s (local, no limit)
LLM_CALL_DELAY=2.5

# ----------------------------------------------------------
# Database — Personal Supabase or local Postgres
# Supabase free tier: https://supabase.com (personal account)
# Local Postgres: postgresql://localhost:5432/jobradar
# NEVER point this at a GEHC-managed database.
# ----------------------------------------------------------
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# ----------------------------------------------------------
# Job Board Credentials — PERSONAL accounts only
# NEVER use corporate SSO or GEHC email.
# ----------------------------------------------------------

# Personal LinkedIn account (non-SSO)
LINKEDIN_EMAIL=your.personal@gmail.com
LINKEDIN_PASSWORD=

# Personal Naukri account
NAUKRI_EMAIL=your.personal@gmail.com
NAUKRI_PASSWORD=

# ----------------------------------------------------------
# Notifications — All personal
# ----------------------------------------------------------

# Telegram Bot (create via @BotFather on personal Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Personal Gmail SMTP (use App Password — not your main password)
# Enable: Google Account → Security → 2FA → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.personal@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx  # Gmail App Password
ALERT_EMAIL_TO=your.personal@gmail.com

# Optional: Slack webhook (personal Slack workspace)
SLACK_WEBHOOK_URL=

# ----------------------------------------------------------
# Pipeline Settings
# ----------------------------------------------------------

# Minimum AI score to trigger an alert (0-100)
MIN_SCORE_ALERT=85

# Minimum estimated salary to keep a job (in rupees, e.g. 7000000 = 70L)
MIN_SALARY_FILTER=7000000

# Max jobs to score per run (controls LLM cost)
MAX_SCORE_PER_RUN=50

# Max auto-apply attempts per day (0 = disabled; requires manual mode)
MAX_AUTO_APPLY_PER_DAY=0

# Manual approval required before submitting applications (true recommended)
MANUAL_APPROVAL=true

# ----------------------------------------------------------
# Security
# ----------------------------------------------------------

# Secret key for encrypting stored credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# ----------------------------------------------------------
# Optional Enhancements
# ----------------------------------------------------------

# Path to your LinkedIn connections CSV export (for referral detection)
# Download from LinkedIn: Settings → Data Privacy → Get a copy of your data
LINKEDIN_CONNECTIONS_CSV=

# Levels.fyi data path (optional, for compensation intelligence)
LEVELS_FYI_CSV=
